<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>An Phan — Game Producer & Project Lead</title>
<meta name="description" content="An Phan: project lead, game designer and producer. Interactive CV & portfolio.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0c0e14;
  --ink-2:#13161f;
  --panel:#1a1e2a;
  --panel-2:#222736;
  --line:#2c3242;
  --fog:#8b93a7;
  --fog-2:#aeb6c8;
  --paper:#ece6d8;
  --gold:#d8a657;
  --gold-soft:#e8c889;
  --cyan:#6fcad6;
  --rose:#c97b8b;
  --white:#f4f1ea;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--ink);
  color:var(--fog-2);
  font-family:'Space Grotesk',system-ui,sans-serif;
  font-size:17px;
  line-height:1.6;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
.mono{font-family:'JetBrains Mono',monospace}
.serif{font-family:'Fraunces',serif}

/* ---------- intro / decipher splash ---------- */
#splash{
  position:fixed;inset:0;z-index:1000;
  background:radial-gradient(circle at 50% 40%, #1a1e2a 0%, #0c0e14 70%);
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  transition:opacity .9s ease, visibility .9s ease;
}
#splash.gone{opacity:0;visibility:hidden;pointer-events:none}
.cipher-line{
  font-family:'JetBrains Mono',monospace;
  font-size:clamp(1.6rem,6vw,3.6rem);
  letter-spacing:.18em;
  color:var(--gold);
  min-height:1.3em;
}
.splash-sub{
  margin-top:1.4rem;color:var(--fog);font-size:.78rem;letter-spacing:.32em;
  text-transform:uppercase;font-family:'JetBrains Mono',monospace;
  opacity:0;animation:fadeIn 1s ease 1.4s forwards;
}
.splash-skip{
  position:absolute;bottom:2rem;font-size:.7rem;letter-spacing:.2em;color:var(--line);
  text-transform:uppercase;cursor:pointer;font-family:'JetBrains Mono',monospace;
  background:none;border:none;transition:color .3s;
}
.splash-skip:hover{color:var(--fog)}
@keyframes fadeIn{to{opacity:1}}

/* ---------- nav ---------- */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.1rem clamp(1.2rem,4vw,3.5rem);
  background:rgba(12,14,20,.0);
  transition:background .4s ease, border-color .4s ease;
  border-bottom:1px solid transparent;
}
nav.solid{background:rgba(12,14,20,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
.nav-name{font-family:'Fraunces',serif;font-weight:600;font-size:1.15rem;color:var(--white);letter-spacing:.01em}
.nav-name span{color:var(--gold)}
.nav-links{display:flex;gap:2rem;align-items:center}
.nav-links a{
  color:var(--fog);text-decoration:none;font-size:.82rem;letter-spacing:.08em;
  text-transform:uppercase;font-family:'JetBrains Mono',monospace;transition:color .25s;
}
.nav-links a:hover{color:var(--gold)}
.nav-cta{
  border:1px solid var(--gold);color:var(--gold)!important;padding:.45rem .9rem;border-radius:2px;
}
.nav-cta:hover{background:var(--gold);color:var(--ink)!important}
.menu-btn{display:none;background:none;border:none;color:var(--white);font-size:1.5rem;cursor:pointer}
@media(max-width:820px){
  .nav-links{
    position:fixed;inset:0;background:var(--ink);flex-direction:column;justify-content:center;
    gap:2rem;transform:translateX(100%);transition:transform .4s ease;
  }
  .nav-links.open{transform:translateX(0)}
  .nav-links a{font-size:1.1rem}
  .menu-btn{display:block;z-index:101}
}

/* ---------- hero ---------- */
.hero{
  min-height:100vh;display:flex;align-items:center;
  padding:7rem clamp(1.2rem,4vw,3.5rem) 4rem;
  position:relative;overflow:hidden;
}
.hero-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);
  background-size:64px 64px;opacity:.12;
  mask-image:radial-gradient(circle at 70% 50%, black 0%, transparent 75%);
}
.hero-inner{position:relative;max-width:1180px;margin:0 auto;width:100%;
  display:grid;grid-template-columns:1.15fr .85fr;gap:3rem;align-items:center}
.hero-eyebrow{
  font-family:'JetBrains Mono',monospace;font-size:.78rem;letter-spacing:.28em;
  text-transform:uppercase;color:var(--gold);margin-bottom:1.6rem;
  display:flex;align-items:center;gap:.7rem;
}
.hero-eyebrow::before{content:"";width:34px;height:1px;background:var(--gold)}
h1.hero-title{
  font-family:'Fraunces',serif;font-weight:600;
  font-size:clamp(2.7rem,7vw,5.4rem);line-height:1.02;color:var(--white);
  letter-spacing:-.01em;margin-bottom:1.4rem;
}
h1.hero-title em{font-style:italic;color:var(--gold)}
.hero-lede{font-size:1.12rem;color:var(--fog-2);max-width:46ch;margin-bottom:2.2rem}
.hero-lede strong{color:var(--white);font-weight:500}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
.btn{
  font-family:'JetBrains Mono',monospace;font-size:.82rem;letter-spacing:.06em;
  padding:.85rem 1.4rem;border-radius:2px;text-decoration:none;cursor:pointer;
  display:inline-flex;align-items:center;gap:.5rem;transition:all .25s;border:1px solid var(--gold);
}
.btn-primary{background:var(--gold);color:var(--ink);font-weight:600}
.btn-primary:hover{background:var(--gold-soft);transform:translateY(-2px)}
.btn-ghost{background:transparent;color:var(--gold)}
.btn-ghost:hover{background:rgba(216,166,87,.1)}
.hero-portrait{
  position:relative;justify-self:center;
}
.portrait-frame{
  width:clamp(220px,28vw,320px);aspect-ratio:1;border-radius:50%;
  overflow:hidden;border:1px solid var(--line);position:relative;
  box-shadow:0 0 0 8px rgba(216,166,87,.05), 0 30px 60px rgba(0,0,0,.5);
}
.portrait-frame img{width:100%;height:100%;object-fit:cover;filter:grayscale(.15) contrast(1.05)}
.portrait-ring{
  position:absolute;inset:-22px;border:1px solid var(--gold);border-radius:50%;
  opacity:.35;animation:spin 40s linear infinite;
}
.portrait-ring::before{content:"◆";position:absolute;top:-9px;left:50%;color:var(--gold);font-size:.8rem}
@keyframes spin{to{transform:rotate(360deg)}}
.portrait-tag{
  position:absolute;bottom:6%;left:-8%;background:var(--panel);border:1px solid var(--line);
  padding:.6rem .9rem;border-radius:3px;font-family:'JetBrains Mono',monospace;font-size:.72rem;
  color:var(--fog-2);box-shadow:0 12px 24px rgba(0,0,0,.4);
}
.portrait-tag b{color:var(--gold)}
@media(max-width:820px){
  .hero-inner{grid-template-columns:1fr;gap:2.5rem}
  .hero-portrait{order:-1}
  .hero-lede{max-width:none}
}

/* ---------- section scaffold ---------- */
section{padding:clamp(4rem,9vw,7rem) clamp(1.2rem,4vw,3.5rem);position:relative}
.wrap{max-width:1180px;margin:0 auto}
.sec-head{margin-bottom:3rem}
.sec-eyebrow{
  font-family:'JetBrains Mono',monospace;font-size:.74rem;letter-spacing:.26em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.9rem;display:flex;align-items:center;gap:.7rem;
}
.sec-eyebrow .num{color:var(--fog);opacity:.6}
h2.sec-title{
  font-family:'Fraunces',serif;font-weight:600;font-size:clamp(2rem,5vw,3.2rem);
  color:var(--white);line-height:1.05;letter-spacing:-.01em;
}
h2.sec-title em{font-style:italic;color:var(--gold)}
.sec-sub{color:var(--fog);max-width:54ch;margin-top:1rem}

/* reveal */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .8s ease, transform .8s ease}
.reveal.in{opacity:1;transform:none}

/* ---------- metrics ---------- */
#impact{background:var(--ink-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);
  border:1px solid var(--line);border-radius:4px;overflow:hidden}
.metric{background:var(--ink-2);padding:2.2rem 1.6rem;transition:background .3s}
.metric:hover{background:var(--panel)}
.metric-num{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(2.4rem,5vw,3.4rem);
  color:var(--gold);line-height:1;letter-spacing:-.02em}
.metric-num .unit{font-size:.5em;color:var(--gold-soft)}
.metric-label{margin-top:.7rem;font-size:.9rem;color:var(--fog-2)}
.metric-ctx{margin-top:.3rem;font-family:'JetBrains Mono',monospace;font-size:.7rem;
  letter-spacing:.04em;color:var(--fog);text-transform:uppercase}
@media(max-width:760px){.metric-grid{grid-template-columns:1fr 1fr}}
@media(max-width:480px){.metric-grid{grid-template-columns:1fr}}

/* ---------- featured project ---------- */
#decypher{background:linear-gradient(180deg,var(--ink) 0%, #11131c 100%)}
.proj-card{
  border:1px solid var(--line);border-radius:6px;overflow:hidden;background:var(--panel);
  box-shadow:0 30px 80px rgba(0,0,0,.45);
}
.proj-top{display:grid;grid-template-columns:1.1fr .9fr}
.proj-frame{position:relative;background:#000;min-height:340px}
.proj-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.proj-poster{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;
  background:radial-gradient(circle at 50% 40%,#2a2030,#0c0e14);cursor:pointer;z-index:2;transition:opacity .4s;
}
.proj-poster.hidden{opacity:0;pointer-events:none}
.play-btn{
  width:74px;height:74px;border-radius:50%;border:1px solid var(--gold);
  display:flex;align-items:center;justify-content:center;background:rgba(216,166,87,.12);
  transition:all .3s;
}
.proj-poster:hover .play-btn{background:var(--gold);transform:scale(1.08)}
.play-btn svg{fill:var(--gold);transition:fill .3s}
.proj-poster:hover .play-btn svg{fill:var(--ink)}
.poster-label{margin-top:1.2rem;font-family:'JetBrains Mono',monospace;font-size:.78rem;
  letter-spacing:.2em;text-transform:uppercase;color:var(--fog-2)}
.poster-hint{margin-top:.5rem;font-family:'JetBrains Mono',monospace;font-size:.66rem;
  letter-spacing:.12em;text-transform:uppercase;color:var(--gold);opacity:.85}
.proj-info{padding:2.4rem 2.2rem;display:flex;flex-direction:column}
.proj-badges{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.2rem}
.badge{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.08em;
  padding:.28rem .6rem;border:1px solid var(--line);border-radius:2px;color:var(--fog-2);text-transform:uppercase}
.badge.hot{border-color:var(--gold);color:var(--gold)}
.proj-title{font-family:'Fraunces',serif;font-weight:600;font-size:1.9rem;color:var(--white);line-height:1.1;margin-bottom:.3rem}
.proj-role{font-family:'JetBrains Mono',monospace;font-size:.8rem;color:var(--gold);letter-spacing:.04em;margin-bottom:1.1rem}
.proj-desc{color:var(--fog-2);font-size:1rem;margin-bottom:1.4rem}
.proj-desc b{color:var(--gold);font-weight:600}
.proj-stats{display:flex;gap:1.8rem;margin-bottom:1.6rem;flex-wrap:wrap}
.proj-stat b{display:block;font-family:'Fraunces',serif;font-size:1.5rem;color:var(--white)}
.proj-stat span{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--fog);text-transform:uppercase;letter-spacing:.06em}
.proj-links{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:auto}
.proj-bottom{border-top:1px solid var(--line);padding:1.6rem 2.2rem;background:var(--ink-2);
  display:flex;gap:2rem;flex-wrap:wrap}
.contrib{flex:1;min-width:200px}
.contrib h4{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.14em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.6rem}
.contrib p{font-size:.9rem;color:var(--fog-2)}
@media(max-width:820px){.proj-top{grid-template-columns:1fr}.proj-frame{min-height:240px}}

/* ---------- timeline ---------- */
.tl{position:relative;margin-left:1rem}
.tl::before{content:"";position:absolute;left:7px;top:6px;bottom:6px;width:1px;
  background:linear-gradient(var(--gold),var(--line))}
.tl-item{position:relative;padding-left:2.4rem;padding-bottom:2.6rem}
.tl-item:last-child{padding-bottom:0}
.tl-dot{position:absolute;left:0;top:5px;width:15px;height:15px;border-radius:50%;
  background:var(--ink);border:1px solid var(--gold);transition:all .3s}
.tl-item:hover .tl-dot{background:var(--gold);box-shadow:0 0 0 5px rgba(216,166,87,.15)}
.tl-date{font-family:'JetBrains Mono',monospace;font-size:.74rem;letter-spacing:.06em;color:var(--gold);margin-bottom:.3rem}
.tl-role{font-family:'Fraunces',serif;font-weight:600;font-size:1.25rem;color:var(--white);line-height:1.2}
.tl-org{font-size:.92rem;color:var(--fog);margin-bottom:.7rem}
.tl-org b{color:var(--fog-2)}
.tl-points{list-style:none}
.tl-points li{position:relative;padding-left:1.1rem;font-size:.95rem;color:var(--fog-2);margin-bottom:.35rem}
.tl-points li::before{content:"›";position:absolute;left:0;color:var(--gold)}
.tl-points li b{color:var(--white);font-weight:500}

/* ---------- leadership cards ---------- */
.lead-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.2rem}
.lead-card{
  border:1px solid var(--line);border-radius:5px;background:var(--panel);padding:1.8rem;
  cursor:pointer;transition:all .3s;position:relative;overflow:hidden;
}
.lead-card::after{content:"+";position:absolute;top:1.3rem;right:1.4rem;color:var(--gold);
  font-family:'JetBrains Mono',monospace;font-size:1.1rem;transition:transform .3s}
.lead-card.open::after{transform:rotate(45deg)}
.lead-card:hover{border-color:var(--gold);background:var(--panel-2)}
.lead-tag{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.14em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.7rem}
.lead-h{font-family:'Fraunces',serif;font-weight:600;font-size:1.25rem;color:var(--white);
  line-height:1.2;margin-bottom:.5rem;max-width:90%}
.lead-teaser{font-size:.92rem;color:var(--fog)}
.lead-body{max-height:0;overflow:hidden;transition:max-height .45s ease, margin .45s ease}
.lead-card.open .lead-body{max-height:340px;margin-top:1rem}
.lead-body p{font-size:.92rem;color:var(--fog-2);margin-bottom:.7rem}
.lead-body .paro{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--gold);
  text-transform:uppercase;letter-spacing:.1em;margin-bottom:.2rem;margin-top:.8rem}
@media(max-width:760px){.lead-grid{grid-template-columns:1fr}}

/* ---------- skills ---------- */
#skills{background:var(--ink-2);border-top:1px solid var(--line)}
.skill-cols{display:grid;grid-template-columns:1fr 1.3fr;gap:3rem}
.lang-row{margin-bottom:1.3rem}
.lang-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.4rem}
.lang-name{font-family:'Fraunces',serif;font-size:1.1rem;color:var(--white)}
.lang-lvl{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--gold);letter-spacing:.06em}
.lang-bar{height:5px;background:var(--line);border-radius:3px;overflow:hidden}
.lang-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-soft));width:0;
  border-radius:3px;transition:width 1.2s cubic-bezier(.2,.8,.2,1)}
.tool-group{margin-bottom:1.4rem}
.tool-group h4{font-family:'JetBrains Mono',monospace;font-size:.74rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.7rem}
.chips{display:flex;flex-wrap:wrap;gap:.5rem}
.chip{font-family:'JetBrains Mono',monospace;font-size:.78rem;padding:.4rem .8rem;
  border:1px solid var(--line);border-radius:3px;color:var(--fog-2);background:var(--ink);transition:all .25s}
.chip:hover{border-color:var(--gold);color:var(--gold)}
@media(max-width:760px){.skill-cols{grid-template-columns:1fr;gap:2.4rem}}

/* ---------- activities ---------- */
.act-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.2rem}
.act{border:1px solid var(--line);border-left:2px solid var(--gold);border-radius:4px;
  padding:1.5rem 1.6rem;background:var(--panel);transition:transform .3s,border-color .3s}
.act:hover{transform:translateY(-3px)}
.act-tag{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.6rem}
.act h4{font-family:'Fraunces',serif;font-size:1.15rem;color:var(--white);margin-bottom:.4rem;line-height:1.25}
.act p{font-size:.9rem;color:var(--fog)}
.act a{color:var(--cyan);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .2s}
.act a:hover{border-color:var(--cyan)}
@media(max-width:760px){.act-grid{grid-template-columns:1fr}}

/* ---------- contact ---------- */
#contact{text-align:center;background:radial-gradient(circle at 50% 0%,#1a1e2a,var(--ink) 70%)}
.contact-cipher{font-family:'JetBrains Mono',monospace;font-size:.8rem;letter-spacing:.3em;
  color:var(--gold);text-transform:uppercase;margin-bottom:1.4rem}
.contact-h{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(2.2rem,6vw,4rem);
  color:var(--white);line-height:1.05;margin-bottom:1.6rem}
.contact-h em{font-style:italic;color:var(--gold)}
.contact-links{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2.2rem}
footer{padding:2.5rem;text-align:center;border-top:1px solid var(--line);
  font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--fog);letter-spacing:.06em}
footer .eg{color:var(--gold);cursor:pointer}

/* easter egg toast */
#egg{position:fixed;bottom:1.5rem;left:50%;transform:translate(-50%,140%);z-index:200;
  background:var(--gold);color:var(--ink);padding:.9rem 1.4rem;border-radius:3px;
  font-family:'JetBrains Mono',monospace;font-size:.82rem;font-weight:600;
  box-shadow:0 16px 40px rgba(0,0,0,.5);transition:transform .5s cubic-bezier(.2,.9,.2,1)}
#egg.show{transform:translate(-50%,0)}

@media(prefers-reduced-motion:reduce){
  *{animation:none!important;transition:none!important}
  .reveal{opacity:1;transform:none}
}
::selection{background:var(--gold);color:var(--ink)}
</style>
</head>
<body>

<!-- splash -->
<div id="splash">
  <div class="cipher-line mono" id="cipher"></div>
  <div class="splash-sub">decrypting profile…</div>
  <button class="splash-skip mono" onclick="endSplash()">skip ↵</button>
</div>

<!-- nav -->
<nav id="nav">
  <div class="nav-name">An <span>Phan</span></div>
  <div class="nav-links" id="navlinks">
    <a href="#decypher" onclick="closeMenu()">Work</a>
    <a href="#journey" onclick="closeMenu()">Journey</a>
    <a href="#leadership" onclick="closeMenu()">Leadership</a>
    <a href="#skills" onclick="closeMenu()">Skills</a>
    <a href="#contact" class="nav-cta" onclick="closeMenu()">Contact</a>
  </div>
  <button class="menu-btn" onclick="toggleMenu()" id="menubtn">☰</button>
</nav>

<!-- hero -->
<header class="hero">
  <div class="hero-grid"></div>
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Project Lead · Game Designer · Producer</div>
      <h1 class="hero-title">I bring <em>structure</em> to creative chaos.</h1>
      <p class="hero-lede">Business graduate turned game producer. I lead multidisciplinary teams, keep production pipelines moving, and turn <strong>scattered ideas into shipped products</strong> — most recently a language-puzzle game presented at Supercell.</p>
      <div class="hero-actions">
        <a href="#decypher" class="btn btn-primary">▶ See my shipped game</a>
        <a href="#" class="btn btn-ghost" id="dlBtn">↓ Download CV</a>
      </div>
    </div>
    <div class="hero-portrait">
      <div class="portrait-ring"></div>
      <div class="portrait-frame">
        <img src="portrait.jpg" alt="An Phan portrait">
      </div>
      <div class="portrait-tag mono">Helsinki, FI · <b>open to work</b></div>
    </div>
  </div>
</header>

<!-- impact metrics -->
<section id="impact">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-eyebrow"><span class="num">01</span> Impact at a glance</div>
      <h2 class="sec-title">Numbers I've <em>moved.</em></h2>
    </div>
    <div class="metric-grid reveal">
      <div class="metric"><div class="metric-num"><span data-count="600" data-suffix="+"></span></div><div class="metric-label">Organic followers built</div><div class="metric-ctx">From zero · in 3 months</div></div>
      <div class="metric"><div class="metric-num">€<span data-count="3690"></span></div><div class="metric-label">Raised via crowdfunding</div><div class="metric-ctx">Short film campaign</div></div>
      <div class="metric"><div class="metric-num"><span data-count="25" data-suffix="%"></span></div><div class="metric-label">User retention lift</div><div class="metric-ctx">Data-driven content</div></div>
