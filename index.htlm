<div id="egg" class="mono">◆ Nothing here is random. — DeCypher</div>

<script>
// ---- splash decipher animation ----
const target = "AN PHAN";
const glyphs = "▓▒░#@%&$?*▚◆◢◣01";
const el = document.getElementById('cipher');
let frame = 0, done = false;
function scramble(){
  if(done) return;
  let out = "";
  for(let i=0;i<target.length;i++){
    if(target[i]===" "){ out+=" "; continue; }
    const settled = i < frame/3;
    out += settled ? target[i] : glyphs[Math.floor(Math.random()*glyphs.length)];
  }
  el.textContent = out;
  frame++;
  if(frame/3 > target.length+1){ el.textContent = target; done=true; setTimeout(endSplash,1100); return; }
  setTimeout(scramble, 70);
}
function endSplash(){
  done=true;
  document.getElementById('splash').classList.add('gone');
}
window.addEventListener('load',()=>{ scramble(); });
// safety auto-end
setTimeout(endSplash, 6000);

// ---- nav ----
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>{ nav.classList.toggle('solid', window.scrollY>40); });
function toggleMenu(){ const l=document.getElementById('navlinks'); l.classList.toggle('open');
  document.getElementById('menubtn').textContent = l.classList.contains('open')?'✕':'☰'; }
function closeMenu(){ document.getElementById('navlinks').classList.remove('open');
  document.getElementById('menubtn').textContent='☰'; }

// ---- reveal on scroll ----
const io=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
},{threshold:.15});
document.querySelectorAll('.reveal').forEach(r=>io.observe(r));

// ---- count up ----
const counted=new WeakSet();
const cio=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(!e.isIntersecting) return;
    e.target.querySelectorAll('[data-count]').forEach(n=>{
      if(counted.has(n)) return; counted.add(n);
      const tgt=+n.dataset.count, suf=n.dataset.suffix||''; let cur=0;
      const step=tgt/45;
      const t=setInterval(()=>{ cur+=step; if(cur>=tgt){cur=tgt;clearInterval(t);}
        n.textContent=Math.floor(cur).toLocaleString()+suf; },20);
    });
  });
},{threshold:.4});
document.querySelectorAll('.metric-grid').forEach(m=>cio.observe(m));

// ---- language bars ----
const lio=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{ if(!e.isIntersecting) return;
    e.target.querySelectorAll('.lang-fill').forEach(f=>{ f.style.width=f.dataset.w+'%'; });
    lio.unobserve(e.target);
  });
},{threshold:.3});
const langs=document.getElementById('langs'); if(langs) lio.observe(langs);

// ---- leadership cards ----
function toggleCard(c){ c.classList.toggle('open'); }

// ---- game player ----
// To embed the game so it plays INSIDE this page, open itch.io →
// Edit Game → Distribute → "Embed game", copy the numeric ID from the
// embed-upload URL, and paste it below. Leave empty to open in a new tab.
const ITCH_EMBED_ID = ""; // e.g. "2368949"
const ITCH_URL = "https://dream-decypher.itch.io/decypher1-dream-intruder";

function loadGame(){
  const frame=document.querySelector('.proj-frame');
  const poster=document.getElementById('poster');
  if(ITCH_EMBED_ID){
    const ifr=document.createElement('iframe');
    ifr.src="https://itch.io/embed-upload/"+ITCH_EMBED_ID+"?color=222736";
    ifr.allowFullscreen=true;
    ifr.allow="autoplay; fullscreen";
    frame.appendChild(ifr);
    poster.classList.add('hidden');
  } else {
    window.open(ITCH_URL,"_blank","noopener");
  }
}

// ---- download CV ----
document.getElementById('dlBtn').addEventListener('click',(e)=>{
  e.preventDefault();
  const a=document.createElement('a'); a.href="An_Phan_CV.pdf"; a.download="An_Phan_CV.pdf";
  document.body.appendChild(a); a.click(); a.remove();
});

// ---- easter egg ----
function reveal(){
  const t=document.getElementById('egg'); t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3200);
}
let keys=[];
window.addEventListener('keydown',(e)=>{
  keys.push(e.key.toLowerCase()); keys=keys.slice(-6);
  if(keys.join('')==='cypher'){ reveal(); }
});
</script>
</body>
</html>
